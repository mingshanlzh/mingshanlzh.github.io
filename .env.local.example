# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Optional: email notifications for CV requests / contact forms ──────────
# Use Resend, SendGrid, or similar SMTP provider
RESEND_API_KEY=re_...

# ─── DO NOT commit .env.local to git ────────────────────────────────────────
# This file is .env.local.example — copy it to .env.local and fill in values
